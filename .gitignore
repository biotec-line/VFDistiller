# ===========================================================================
# VFDistiller .gitignore — GitHub Release
# ===========================================================================

# ---------------------------------------------------------------------------
# Genomreferenzen (mehrere GB, niemals in Git)
# ---------------------------------------------------------------------------
*.fa
*.fasta
*.fna
*.fai
*.fa.gz
*.fasta.gz

# ---------------------------------------------------------------------------
# Datenbanken (nutzerspezifisch, werden zur Laufzeit erzeugt)
# ---------------------------------------------------------------------------
*.db
*.sqlite
*.db-journal
*.db-wal
*.db-shm

# ---------------------------------------------------------------------------
# Persoenliche Daten / Testdaten / Credentials
# ---------------------------------------------------------------------------
_persönlich/
converted_23andme_vcfs/

# ---------------------------------------------------------------------------
# Nutzerkonfiguration (enthaelt API-Keys und lokale Pfade)
# ---------------------------------------------------------------------------
variant_fusion_settings.json
resources_config.json

# ---------------------------------------------------------------------------
# Laufzeit-generierte Daten
# ---------------------------------------------------------------------------
cache.json
distiller_debug.log
logs/
.vf_instance.lock

# ---------------------------------------------------------------------------
# Data-Verzeichnis (Annotationen separat tracken)
# ---------------------------------------------------------------------------
data/lightdb_config.json
data/annotations/*_index.pkl

# ---------------------------------------------------------------------------
# Cache / Bytecode
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
.mypy_cache/
.pytest_cache/

# ---------------------------------------------------------------------------
# Cython Build-Artefakte
# ---------------------------------------------------------------------------
cython_hotpath/*.so
cython_hotpath/*.pyd
cython_hotpath/*.c
cython_hotpath/*.html
cython_hotpath/build/

# ---------------------------------------------------------------------------
# Build-Output / Releases
# ---------------------------------------------------------------------------
dist/
build/
_OUTPUT EXE/
releases/

# ---------------------------------------------------------------------------
# Archiv- und Wartungsversionen (nicht fuer GitHub)
# ---------------------------------------------------------------------------
_archive/
_alt/
_WARTUNG/

# ---------------------------------------------------------------------------
# Interne Entwicklungs-Dateien
# ---------------------------------------------------------------------------
AUFGABEN.txt
classes.txt
.claude/
COMPLETE_PROJECT_CONTEXT.txt

# ---------------------------------------------------------------------------
# OS-spezifisch
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*.lnk

# ---------------------------------------------------------------------------
# IDE
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
